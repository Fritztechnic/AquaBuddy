<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<StackPane fx:id="rootPane"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.waterreminder.controller.MainController"
           styleClass="root-pane">

    <!-- ======== HAUPT-CONTAINER ======== -->
    <VBox fx:id="mainContainer" alignment="CENTER" spacing="0" styleClass="main-container">

        <!-- ===== HEADER ===== -->
        <VBox alignment="CENTER" spacing="4" styleClass="header-section">
            <padding><Insets top="14" bottom="6" left="16" right="16"/></padding>

            <Label text="AquaBuddy" styleClass="app-title"/>
            <Label fx:id="greetingLabel" text="Willkommen!" styleClass="greeting-label"/>
        </VBox>

        <!-- ===== WASSER-TROPFEN-BEREICH ===== -->
        <VBox alignment="CENTER" spacing="6" styleClass="drop-section">
            <padding><Insets top="8" bottom="6" left="16" right="16"/></padding>

            <Label fx:id="waterDropEmoji" text="💧" styleClass="water-drop-emoji"/>

            <!-- Glas-Zähler -->
            <HBox alignment="CENTER" spacing="4">
                <Label fx:id="glassCountLabel" text="0" styleClass="glass-count"/>
                <Label fx:id="goalLabel" text="/ 8 Gläser" styleClass="goal-text"/>
            </HBox>

            <Label fx:id="totalMlLabel" text="0.0 L getrunken" styleClass="total-ml"/>
        </VBox>

        <!-- ===== PROGRESS BAR ===== -->
        <VBox alignment="CENTER" spacing="4" styleClass="progress-section">
            <padding><Insets top="4" bottom="8" left="28" right="28"/></padding>

            <ProgressBar fx:id="progressBar" progress="0" maxWidth="Infinity" styleClass="water-progress"/>
            <Label fx:id="progressPercentLabel" text="0%" styleClass="progress-percent"/>
        </VBox>

        <!-- ===== NACHRICHT ===== -->
        <VBox alignment="CENTER" styleClass="message-section">
            <padding><Insets top="8" bottom="8" left="24" right="24"/></padding>

            <Label fx:id="messageLabel" text="Bereit zum Trinken? 💧"
                   styleClass="message-label" wrapText="true" alignment="CENTER"/>
        </VBox>

        <!-- ===== DRINK BUTTON ===== -->
        <VBox alignment="CENTER" spacing="8" styleClass="button-section">
            <padding><Insets top="6" bottom="6" left="24" right="24"/></padding>

            <Button fx:id="drinkButton" text="Getrunken!"
                    onAction="#onDrinkButtonClicked" styleClass="drink-button"
                    maxWidth="260" prefHeight="44"/>

            <Button fx:id="undoButton" text="↩️ Rückgängig"
                    onAction="#onUndoClicked" styleClass="undo-button"/>
        </VBox>

        <!-- ===== TIMER & STATS ===== -->
        <VBox alignment="CENTER" spacing="6" styleClass="stats-section">
            <padding><Insets top="8" bottom="8" left="24" right="24"/></padding>

            <Label fx:id="timerLabel" text="⏰ Nächste Erinnerung: --:--" styleClass="timer-label"/>

            <HBox alignment="CENTER" spacing="24">
                <Label fx:id="streakLabel" text="🔥 0 Tage Streak" styleClass="streak-label"/>
                <Label fx:id="lastDrinkLabel" text="Zuletzt: --:--" styleClass="last-drink-label"/>
            </HBox>
        </VBox>

        <!-- ===== FAKTEN-BOX ===== -->
        <VBox alignment="CENTER" styleClass="fact-section">
            <padding><Insets top="8" bottom="8" left="24" right="24"/></padding>

            <Label fx:id="factLabel" text="💡 Lade Wasser-Fakten..."
                   styleClass="fact-label" wrapText="true" alignment="CENTER"/>
        </VBox>

        <!-- ===== EINSTELLUNGEN ===== -->
        <VBox alignment="CENTER" spacing="8" styleClass="settings-section">
            <padding><Insets top="10" bottom="18" left="28" right="28"/></padding>

            <Label text="⚙️ Einstellungen" styleClass="settings-title"/>

            <!-- Erinnerungs-Intervall -->
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="⏱️ Erinnerung alle:" styleClass="setting-label"/>
                <Slider fx:id="intervalSlider" HBox.hgrow="ALWAYS"/>
                <Label fx:id="intervalValueLabel" text="30 min" styleClass="setting-value" minWidth="55"/>
            </HBox>

            <!-- Tagesziel -->
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="🎯 Tagesziel:" styleClass="setting-label"/>
                <Slider fx:id="goalSlider" HBox.hgrow="ALWAYS"/>
                <Label fx:id="goalValueLabel" text="8 Gläser" styleClass="setting-value" minWidth="55"/>
            </HBox>
        </VBox>

    </VBox>

    <!-- ======== FEIER-OVERLAY ======== -->
    <VBox fx:id="celebrationOverlay" alignment="CENTER" visible="false" styleClass="celebration-overlay">
        <padding><Insets top="40" bottom="40" left="30" right="30"/></padding>
    </VBox>

</StackPane>
